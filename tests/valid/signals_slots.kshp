using Sys;
using Sys.Application;

namespace KSharp.Tests {
    public class Enemy {
        public property int Health = 50;
        public property string Name = "Enemy";

        public signal void Died();
        public signal void Damaged(int amount);

        public slot void TakeDamage(int amount) {
            this.Health -= amount;
            Damaged(amount);
            if (this.Health <= 0) {
                Died();
            }
        }
    }

    public class SignalsApp : ConsoleApplication {
        public static void Main(string[] args) {
            Console.WriteLine("Signals test");
        }
    }
}
